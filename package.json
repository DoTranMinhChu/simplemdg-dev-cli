{
  "name": "simplemdg-dev-cli",
  "version": "3.0.0",
  "description": "SimpleMDG local development CLI with CF/BTP helpers, CAP helpers, GitLab sync, request trace, and BTP DB Studio.",
  "type": "module",
  "bin": {
    "simplemdg": "dist/index.js",
    "smdg": "dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "USER_GUIDE.md",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "npm run build:studio && npm run build:cli",
    "build:cli": "tsup",
    "build:studio": "cd studio && npm install && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "dev:cli": "tsx src/index.ts",
    "dev:studio": "cd studio && npm run dev",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "bump:patch": "npm version patch --no-git-tag-version",
    "bump:minor": "npm version minor --no-git-tag-version",
    "bump:major": "npm version major --no-git-tag-version"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.1",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "ink": "^5.0.1",
    "prompts": "^2.4.2",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/prompts": "^2.4.9",
    "@types/react": "^18.3.12",
    "@types/pg": "^8.11.10",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "pg": "^8.12.0",
    "@sap/hana-client": "^2.23.24"
  }
}
